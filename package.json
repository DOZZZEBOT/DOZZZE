{
  "name": "dozzze",
  "version": "0.1.0",
  "private": true,
  "description": "DOZZZE — idle compute enhancer, MVP workspaces root",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dozzze": "npm run dozzze --workspace packages/node --"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
