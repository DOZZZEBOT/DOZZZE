{
  "name": "@dozzze/node",
  "version": "0.4.0",
  "description": "DOZZZE node client — put your idle compute to work",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "dozzze": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dozzze": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@dozzze/client": "^0.4.0",
    "@dozzze/sdk": "^0.4.0",
    "@solana/web3.js": "^1.95.3",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
